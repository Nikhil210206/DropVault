# Prisma CLI (migrate / seed / studio) reads this file from the repo root.
# Pooled connection (PgBouncer in prod). Locally this is the direct Postgres.
DATABASE_URL="postgresql://dropvault:dropvault@localhost:5433/dropvault?schema=public"
# Direct connection used by `prisma migrate` (bypasses the pooler in prod).
DIRECT_URL="postgresql://dropvault:dropvault@localhost:5433/dropvault?schema=public"
