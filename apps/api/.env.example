# ── Core ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ── Database (Postgres via docker-compose) ────────────────────────────
DATABASE_URL="postgresql://dropvault:dropvault@localhost:5433/dropvault?schema=public"
DIRECT_URL="postgresql://dropvault:dropvault@localhost:5433/dropvault?schema=public"

# ── Redis (cache, rate-limit, queues) ─────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── HTTP / security ───────────────────────────────────────────────────
# Comma-separated list of allowed browser origins (exact match, with credentials).
CORS_ORIGINS="http://localhost:3000"
# Number of proxies in front of the app (Render/Vercel = 1). 0 = none (local).
TRUST_PROXY=0
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Auth (JWT, EdDSA) ─────────────────────────────────────────────────
# Base64-encoded PEM keys. Generate a dev pair with:
#   node -e "import('jose').then(async j=>{const{privateKey,publicKey}=await j.generateKeyPair('EdDSA',{crv:'Ed25519',extractable:true});console.log('JWT_PRIVATE_KEY='+Buffer.from(await j.exportPKCS8(privateKey)).toString('base64'));console.log('JWT_PUBLIC_KEY='+Buffer.from(await j.exportSPKI(publicKey)).toString('base64'))})"
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KID=dev-1
JWT_ISSUER=dropvault
JWT_AUDIENCE=dropvault-api
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL_DAYS=7

# ── Email + web ───────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
MAIL_FROM="DropVault <no-reply@dropvault.local>"
MAIL_TRANSPORT=smtp        # smtp (Mailpit local) | resend (prod)
SMTP_HOST=localhost
SMTP_PORT=1025
# RESEND_API_KEY=re_...     # required when MAIL_TRANSPORT=resend

# ── Added in later phases ─────────────────────────────────────────────
# S3_ENDPOINT / S3_BUCKET / S3_*_KEY    → Phase 5 (uploads)
