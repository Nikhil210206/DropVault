# syntax=docker/dockerfile:1
# Multi-stage build for the Next.js web app using standalone output (slim runtime).
# Build context is the monorepo root.

FROM node:22-bookworm-slim AS base
RUN corepack enable
WORKDIR /app

# ---- build ----
FROM base AS build
# NEXT_PUBLIC_* is inlined at build time, so the public API URL is a build arg.
ARG NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_TELEMETRY_DISABLED=1
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @dropvault/web build

# ---- runtime (standalone server only) ----
FROM base AS runner
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
WORKDIR /app
# Standalone output mirrors the monorepo layout under the tracing root.
COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
USER node
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
